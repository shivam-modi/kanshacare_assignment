# ============================================================
# Kansha Care — environment variables
# Copy to .env (local) and fill in values. Never commit .env.
# ============================================================

# --- Runtime --------------------------------------------------
ENV=local                          # local | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # json | console

# --- MongoDB --------------------------------------------------
# Local docker-compose: mongodb://mongo:27017
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DB=kanshacare

# --- Redis (arq job queue) -----------------------------------
# Local docker-compose: redis://redis:6379
# Upstash: rediss://default:<token>@<host>:6379
REDIS_URL=redis://localhost:6379

# --- USGS feeds -----------------------------------------------
USGS_HOUR_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
USGS_MONTH_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_month.geojson
USGS_POLL_INTERVAL_SECONDS=60
USGS_REQUEST_TIMEOUT_SECONDS=10
USGS_BACKFILL_ON_BOOT=true         # set false to skip backfill (after first run)

# --- Geocoding ------------------------------------------------
# Provider is pluggable: nominatim | locationiq | mapbox
GEOCODER_PROVIDER=nominatim
GEOCODER_USER_AGENT=kanshacare-dev (contact@example.com)
GEOCODER_RATE_LIMIT_PER_SEC=1
# Provider-specific (only the chosen one is read)
LOCATIONIQ_API_KEY=
MAPBOX_API_KEY=

# --- Telegram -------------------------------------------------
TELEGRAM_BOT_TOKEN=                # from @BotFather
TELEGRAM_WEBHOOK_SECRET=           # random string, set as secret_token in setWebhook
TELEGRAM_WEBHOOK_BASE_URL=         # public https URL of alerts-svc, e.g. https://kanshacare-alerts.fly.dev

# --- Alerting rules (overridable per env) ---------------------
ALERT_GLOBAL_MAG_THRESHOLD=5.0
ALERT_NEAR_MAG_THRESHOLD=4.0
ALERT_NEAR_RADIUS_KM=500
SWARM_WINDOW_MINUTES=30
SWARM_RADIUS_KM=200
SWARM_MIN_EVENTS=5
SILENCE_THRESHOLD_MINUTES=10
SILENCE_CHECK_INTERVAL_SECONDS=120
SILENCE_REALERT_SUPPRESSION_MINUTES=30

# --- Daily summary --------------------------------------------
DAILY_SUMMARY_HOUR_UTC=9           # 0-23, hour to fire the daily digest
DAILY_SUMMARY_MINUTE=0

# --- API / Web ------------------------------------------------
API_PORT=8001
API_CORS_ORIGINS=http://localhost:3000
API_RATE_LIMIT_SUMMARY_PER_MINUTE=1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_DASHBOARD_BASE_URL=http://localhost:3000

# --- Service ports (docker-compose) --------------------------
INGESTION_PORT=8000
ALERTS_PORT=8002
WORKER_HEALTH_PORT=8003
