# Copy to .env.production (gitignored) and fill in real values.
# These never get committed; the deploy script reads them and pushes
# them to Fly's encrypted secret store via `flyctl secrets set`.

# --- Mongo Atlas SRV string (mongodb+srv://USER:PASS@cluster.mongodb.net/...) ---
MONGO_URI=

# --- Upstash Redis (rediss://default:TOKEN@host.upstash.io:6379) ----------
REDIS_URL=

# --- Telegram bot from BotFather ------------------------------------------
TELEGRAM_BOT_TOKEN=

# --- A random string you generate. Telegram echoes this in every webhook
#     header so we can verify the request really came from Telegram.
#     Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# --- Identifies your deployment to Nominatim per their usage policy --------
# Quote the whole value — the parentheses are bash-special otherwise.
GEOCODER_USER_AGENT="kanshacare-prod (your-email@example.com)"

# --- The Fly app names (you usually leave these as-is) ---------------------
APP_INGESTION=kanshacare-ingestion
APP_API=kanshacare-api
APP_ALERTS=kanshacare-alerts
APP_WORKER=kanshacare-worker
APP_WEB=kanshacare-web
